# ============================================================================
#  Copy this file to .env and fill in the values.
#  The script reads these via process.env (or GitHub Secrets in CI).
# ============================================================================

# Full Chili tracking URL (contains the unique token)
TRACKING_URL=https://web.chili.co.il/deliveryzCoordinateApp/app/YOUR-TOKEN-HERE

# Neve Schechter event page to monitor for ticket availability
NEVE_TICKET_URL=https://neve-schechter.org.il/product/moadon-64/
NEVE_ALERT_ON_FIRST_RUN=false

# SMTP settings (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-16-char-app-password

# Where to send the alert
NOTIFY_EMAIL=recipient@example.com

# "browser" (Puppeteer, default) or "api" (direct JSON fetch)
PARSING_MODE=browser

# Set true to inspect slots without requiring or sending email.
DRY_RUN=true

# Send one daily status email from the 10:00 Israel-time run.
LIFE_SIGNAL_ENABLED=true
LIFE_SIGNAL_TZ=Asia/Jerusalem
LIFE_SIGNAL_HOUR=10
LIFE_SIGNAL_MINUTE=0
LIFE_SIGNAL_WINDOW_MINUTES=15
LIFE_SIGNAL_FORCE=false
